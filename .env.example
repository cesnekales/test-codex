# Required: export Facebook session cookies as JSON array for Playwright context.add_cookies
# Example cookie object keys: name,value,domain,path,httpOnly,secure,sameSite
FB_SESSION_COOKIES_JSON=[{"name":"c_user","value":"<user_id>","domain":".facebook.com","path":"/","httpOnly":true,"secure":true,"sameSite":"Lax"},{"name":"xs","value":"<xs_token>","domain":".facebook.com","path":"/","httpOnly":true,"secure":true,"sameSite":"Lax"}]

# Marketplace URL targeting Czech listings
FB_MARKETPLACE_URL=https://www.facebook.com/marketplace/prague/search?query=pron%C3%A1jem%20byt

# Group feed URL targeting Czech real-estate groups
FB_GROUP_URL=https://www.facebook.com/groups/REPLACE_WITH_GROUP_ID

# true|false
HEADLESS=true
